# ── Local server ─────────────────────────────────────────────────────────────
PORT=4173
HOST=0.0.0.0

# ── AllAnime (primary online source — no key required) ───────────────────────
# No configuration needed; the proxy at /api/allanime/* handles it automatically.

# ── JIMOV / TioAnime (primary online source — no key required) ───────────────
# Defaults to the public JIMOV instance. Override only if you self-host.
JIMOV_API=https://jimov-api.vercel.app

# ── ZenkaiTV scraper service (TioAnime + AnimeAV1 sources) ───────────────────
# The Python Flask service (folder: scraper / your test repo, app.py).
# Local:  http://localhost:5000
# Hosted: set to your deployed scraper URL, e.g. https://zenkaitv-scraper.onrender.com
TIOANIME_API=http://localhost:5000

# ── Anime1v (optional local/self-hosted source) ───────────────────────────────
# Local default. For Vercel/online deployment replace with a public HTTPS URL,
# or leave unset — AnimeTV will gracefully skip it when unreachable.
ANIME1V_API=http://localhost:3001
ANIME1V_PATH=
ANIME1V_API_KEY=dev-anime1v-key
ANIME1V_AUTO_START=true

# ── Consumet KickAssAnime (optional self-hosted source) ──────────────────────
# Local default. For Vercel/online deployment use a public HTTPS Consumet instance
# you control (e.g. deploy riimuru/consumet-api on Railway or Render).
# Leave unset to skip this source gracefully.
CONSUMET_API=http://localhost:3000
CONSUMET_CATALOG_LIMIT=360
CONSUMET_SEARCH_PAGES=6
CONSUMET_TIMEOUT_MS=7000

# ── RapidAPI Anime (optional paid source) ────────────────────────────────────
# Set both variables if you have a RapidAPI subscription.
# Leave blank to skip this source gracefully.
RAPIDAPI_ANIME_HOST=your-host.p.rapidapi.com
RAPIDAPI_ANIME_KEY=your-rapidapi-key-here
RAPIDAPI_ANIME_TIMEOUT_MS=18000
RAPIDAPI_ANIME_CATALOG_LIMIT=300

# ── Misc ─────────────────────────────────────────────────────────────────────
UPDATE_REPO_URL=https://github.com/JSolanoDev/AnimeTV
DAILY_REFRESH_INTERVAL_MS=86400000
LOG_LEVEL=info
