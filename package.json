{
  "name": "animetv",
  "version": "2.0.0",
  "description": "Modern anime TV app with multi-source catalogs, embedded playback, and Japanese audio plus Spanish subtitle preferences.",
  "main": "animetv-local.js",
  "homepage": "https://animetv-umber.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/JSolanoDev/AnimeTV.git"
  },
  "bugs": {
    "url": "https://github.com/JSolanoDev/AnimeTV/issues"
  },
  "scripts": {
    "start": "node animetv-local.js",
    "dev": "node animetv-local.js",
    "vercel-build": "node scripts/build-static.mjs",
    "deploy:vercel": "powershell -NoProfile -ExecutionPolicy Bypass -File ./deploy-vercel.ps1",
    "check": "node --check animetv-local.js && node --check animetv-server.js && node --check api/[...path].js && node --check client.js",
    "android:build": "cd android && .\\gradlew.bat assembleDebug",
    "android:install": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "keywords": [
    "anime",
    "android-tv",
    "streaming",
    "japanese-audio",
    "spanish-subtitles"
  ],
  "author": "JSolanoDev",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
