{
  "framework": null,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "{animetv-server.js,sources.json,animetv-settings.json,config/**,scraper/*.json}"
    }
  },
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/logo-round.png" },
    { "source": "/api/(.*)", "destination": "/api/[...path]" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security",  "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy",     "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: http: https:; media-src 'self' blob: http: https:; connect-src 'self' http: https: ws: wss:; frame-src 'self' http: https: blob:; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; navigate-to 'self'" },
        { "key": "Referrer-Policy",             "value": "no-referrer" },
        { "key": "X-Content-Type-Options",      "value": "nosniff" },
        { "key": "X-Frame-Options",             "value": "SAMEORIGIN" },
        { "key": "Cross-Origin-Opener-Policy",  "value": "same-origin" },
        { "key": "Permissions-Policy",          "value": "autoplay=*, fullscreen=*, picture-in-picture=*, camera=(), microphone=(), geolocation=(), payment=(), usb=(), serial=(), xr-spatial-tracking=()" },
        { "key": "Cache-Control",               "value": "public, max-age=60, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/api/catalog",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=900, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/api/(anilist|jikan)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=1800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/api/(animeav1|tioanime|jkanime|animeonlineninja)/slugs",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|svg|webmanifest|ico|png|webp|jpg|jpeg|woff2?|ttf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
